
# Claude Code Python Configuration
# Copy this file to .env and fill in your details

# OpenAI compatible API configuration
CLAUDE_CODE_API_URL=https://api.openai.com/v1
CLAUDE_CODE_API_KEY=your-api-key-here
CLAUDE_CODE_MODEL=gpt-4
CLAUDE_CODE_MAX_CONTEXT_TOKENS=128000
# TUI theme for cc-py. Defaults to atom-one-dark if unset.
CLAUDE_CODE_THEME=atom-one-dark

# gRPC configuration (for frontend-backend separation mode)
CLAUDE_CODE_GRPC_HOST=localhost
CLAUDE_CODE_GRPC_PORT=50051
